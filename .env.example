# 회생ON 환경변수 예시
# 사용법: 이 파일을 복사해 `.env.local` 로 만들고 값을 채우세요.
#   - 로컬 개발(localhost): .env.local 에 설정
#   - 공개 배포(Vercel): Vercel > Settings > Environment Variables 에 동일하게 설정
# 모든 키는 선택사항입니다. 미설정 시 규칙기반/목업으로 동작합니다.

# ── AI 품질 향상 (Claude) ─────────────────────────────
# 발급: https://console.anthropic.com  →  API Keys
ANTHROPIC_API_KEY=
# 선택: 모델 지정 (기본값 claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# ── DB·인증·멀티사무소 (Supabase) ──────────────────────
# 발급: https://supabase.com  →  프로젝트 > Settings > API
# 스키마: supabase/schema.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 정기결제 (토스페이먼츠) ────────────────────────────
# 발급: https://developers.tosspayments.com  (테스트 키 사용 가능)
TOSS_SECRET_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# ── 카카오 알림톡 / SMS (솔라피) ───────────────────────
# 발급: https://solapi.com  →  API Key
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=
# 알림톡(카카오 비즈채널) 사용 시
SOLAPI_PF_ID=
SOLAPI_TEMPLATE_ID=

# ── 데스크톱 설치파일 다운로드 주소 ────────────────────
# 설치파일(.exe/.dmg)을 빌드·호스팅(예: GitHub Releases) 후 주소를 넣으면
# /download 페이지의 버튼이 자동 활성화됩니다. 미설정 시 '준비 중' 표시.
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_DOWNLOAD_WIN=
NEXT_PUBLIC_DOWNLOAD_MAC=
NEXT_PUBLIC_DOWNLOAD_MAC_INTEL=

# ── 공공·행정 서류 자동발급 (CODEF) ────────────────────
# 발급: https://codef.io  →  developer.codef.io 에서 API 키
# 미설정 시 자동발급은 목업(실제 발급 안 됨)으로 동작.
CODEF_CLIENT_ID=
CODEF_CLIENT_SECRET=
# 공개키(RSA) 등 추가 파라미터는 실연동 시 codef.ts에 반영
